# VS AI Proxy runtime configuration
# Copy to .env when running via Docker Compose.

# Proxy / API ports
PROXY_PORT=11434
MANAGEMENT_PORT=12434

# Optional proxy authentication
#PROXY_API_KEY=your-proxy-secret

# Persisted config path is set by docker-compose to /data/config.json.
# You can override it if you run the binary directly.
#CONFIG_PATH=/data/config.json

# Optional request log persistence path.
# If omitted, the binary stores logs.json next to CONFIG_PATH or in the user config dir.
#STORE_PATH=/data/logs.json

# Provider keys and base URLs
PROVIDER_USEAI_BASE_URL=https://api.eforge.xyz/v1
#PROVIDER_USEAI_API_KEY=your-useai-key-if-required

PROVIDER_DEEPSEEK_API_KEY=sk-your-deepseek-key-here
PROVIDER_DEEPSEEK_BASE_URL=https://api.deepseek.com

#PROVIDER_GOOGLE_API_KEY=your-google-gemini-api-key-here
#PROVIDER_OPENAI_API_KEY=sk-your-openai-key-here
#PROVIDER_NVIDIA_API_KEY=nvapi-your-nvidia-key-here
#PROVIDER_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
#PROVIDER_GROQ_API_KEY=gsk_your-groq-key-here
#PROVIDER_OLLAMACLOUD_API_KEY=your-ollama-cloud-api-key
#PROVIDER_OLLAMA_BASE_URL=https://ollama.com

# Legacy compatibility fallback
#DEEPSEEK_API_KEY=sk-your-api-key-here
#DEEPSEEK_BASE_URL=https://api.deepseek.com
