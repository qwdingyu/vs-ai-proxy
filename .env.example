# VS AI Proxy runtime configuration
# Copy to .env when running via Docker Compose.

# Single HTTP endpoint for Visual Studio / Ollama-compatible clients and Web admin.
# Proxy APIs stay at /v1/* and /api/chat|tags|show|version.
# Web admin is available at /admin, and management APIs are under /admin/api/*.
PORT=12345

# The binary binds to 127.0.0.1 by default. Docker sets HOST=0.0.0.0 so the
# single container port can be published explicitly by docker-compose.
#HOST=127.0.0.1

# Docker Compose publishes the container port to loopback by default because
# /admin can read and write provider API keys. Set BIND_HOST=0.0.0.0 only when
# you intentionally expose both proxy APIs and the Web admin to your network.
#BIND_HOST=127.0.0.1

# Cloud host example:
# HOST=0.0.0.0              # binary mode: listen on all network interfaces
# BIND_HOST=0.0.0.0         # docker compose: publish to public interfaces
# ADMIN_API_KEY=change-me   # required when /admin is reachable from the network

# Optional proxy authentication
#PROXY_API_KEY=your-proxy-secret

# Optional Web admin authentication. When set, /admin shows a simple token login
# page and /admin/api/* accepts either the login cookie or Bearer token. If
# omitted, ADMIN_API_KEY falls back to PROXY_API_KEY when PROXY_API_KEY is set.
#ADMIN_API_KEY=your-admin-secret

# Persisted config path is set by docker-compose to /data/config.json.
# You can override it if you run the binary directly.
#CONFIG_PATH=/data/config.json

# Optional request log persistence path.
# If omitted, the binary stores logs.json next to CONFIG_PATH or in the user config dir.
#STORE_PATH=/data/logs.json

# LLM providers, base URLs, API keys, priorities, and model defaults are managed
# in the Web UI and persisted in config.json. Do not configure provider keys here.
