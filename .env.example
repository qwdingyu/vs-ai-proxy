# VS AI Proxy runtime configuration
# Copy this file to .env next to the executable when overrides are needed
# (vs-ai-proxy.exe on Windows or vs-ai-proxy on macOS).

# Single HTTP endpoint for Visual Studio / Ollama-compatible clients and Web admin.
# Proxy APIs stay at /v1/* and /api/chat|tags|show|version.
# Web admin is available at /admin, and management APIs are under /admin/api/*.
PORT=12345

# The executable binds to 127.0.0.1 by default.
#HOST=127.0.0.1

# Optional proxy authentication. Configure this if HOST is not loopback.
#PROXY_API_KEY=your-proxy-secret

# Optional Web admin authentication. If omitted, ADMIN_API_KEY falls back to
# PROXY_API_KEY. Use a different secret when the proxy is available on a LAN.
#ADMIN_API_KEY=your-admin-secret

# Optional persisted config path. The platform default normally needs no override.
#CONFIG_PATH=/path/to/config.json

# Optional request log path. By default logs.json is stored next to CONFIG_PATH.
#STORE_PATH=/path/to/logs.json

# LLM providers, base URLs, API keys, priorities, and model defaults are managed
# in the Web UI and persisted in config.json. Do not configure provider keys here.
